<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EasyButtons.Pages.EditButtonPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:EasyButtons.ViewModels"
    x:DataType="vm:EditButtonViewModel"
    BackgroundColor="#111111">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="FieldBg">#222222</Color>
            <Color x:Key="FieldText">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Preview -->
            <Border
                HeightRequest="150"
                WidthRequest="150"
                StrokeShape="Ellipse"
                StrokeThickness="0"
                BackgroundColor="{Binding Color, Converter={StaticResource HexToColorConverter}}"
                HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="16" Opacity="0.5" />
                </Border.Shadow>
                <Label
                    Text="{Binding Label}"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center"
                    VerticalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    MaxLines="3"
                    Padding="14,0" />
            </Border>

            <!-- Label field -->
            <VerticalStackLayout Spacing="8">
                <Label Text="LABEL" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#222222" Padding="16,12">
                    <Entry Text="{Binding Label}"
                           Placeholder="e.g. Chill Playlist"
                           PlaceholderColor="#555"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           ReturnType="Next" />
                </Border>
            </VerticalStackLayout>

            <!-- Color picker -->
            <VerticalStackLayout Spacing="12">
                <Label Text="COLOR" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />
                <CollectionView ItemsSource="{Binding PresetColors}"
                                SelectionMode="None"
                                HeightRequest="60">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="{x:Type x:String}">
                            <Border WidthRequest="48" HeightRequest="48"
                                    StrokeShape="Ellipse"
                                    StrokeThickness="3"
                                    Stroke="Transparent"
                                    BackgroundColor="{Binding ., Converter={StaticResource HexToColorConverter}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectColorCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Action -->
            <VerticalStackLayout Spacing="8">
                <Label Text="ACTION" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />

                <!-- Open URI -->
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="#222222" Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetActionModeCommand}" CommandParameter="0" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="✓" TextColor="#E53935"
                               FontAttributes="Bold" FontSize="16"
                               IsVisible="{Binding IsUriMode}"
                               WidthRequest="28" />
                        <Label Grid.Column="1" Text="🔗 Open URL / URI" TextColor="White" FontSize="15" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- URI entry (visible when URI mode selected) -->
                <VerticalStackLayout IsVisible="{Binding IsUriMode}" Spacing="6">
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#222222" Padding="16,12">
                        <Entry Text="{Binding Uri}"
                               Placeholder="e.g. spotify:track:4uLU6hMCjMI75M1A2tKUQC"
                               PlaceholderColor="#555"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               Keyboard="Url"
                               ReturnType="Done" />
                    </Border>
                    <Label Text="Supports any URI: spotify:, https://, youtube://, google.navigation:q=Address, etc."
                           FontSize="12" TextColor="#666" />
                </VerticalStackLayout>

                <!-- Play sound -->
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="#222222" Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetActionModeCommand}" CommandParameter="1" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="✓" TextColor="#E53935"
                               FontAttributes="Bold" FontSize="16"
                               IsVisible="{Binding IsSoundMode}"
                               WidthRequest="28" />
                        <Label Grid.Column="1" Text="🔊 Play sound" TextColor="White" FontSize="15" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Sound file picker (visible when sound mode selected) -->
                <VerticalStackLayout IsVisible="{Binding IsSoundMode}" Spacing="6">
                    <Button Text="{Binding SoundFileName}"
                            Command="{Binding PickSoundCommand}"
                            BackgroundColor="#222222"
                            TextColor="White"
                            CornerRadius="12"
                            FontSize="14" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Delete button (edit mode only) -->
            <Button
                IsVisible="{Binding IsEdit}"
                Text="Delete Button"
                BackgroundColor="Transparent"
                BorderColor="#E53935"
                BorderWidth="1"
                TextColor="#E53935"
                CornerRadius="12"
                Command="{Binding DeleteCommand}"
                Margin="0,16,0,0" />

            <!-- Pin to home screen (edit mode + device supports it) -->
            <Button
                IsVisible="{Binding CanPin}"
                Text="📌 Pin to Home Screen"
                BackgroundColor="Transparent"
                BorderColor="#555"
                BorderWidth="1"
                TextColor="#AAA"
                CornerRadius="12"
                Command="{Binding PinShortcutCommand}"
                Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
