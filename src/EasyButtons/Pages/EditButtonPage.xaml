<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EasyButtons.Pages.EditButtonPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:EasyButtons.ViewModels"
    x:DataType="vm:EditButtonViewModel"
    BackgroundColor="#111111">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="FieldBg">#222222</Color>
            <Color x:Key="FieldText">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Preview -->
            <Border
                HeightRequest="150"
                WidthRequest="150"
                StrokeShape="Ellipse"
                StrokeThickness="0"
                BackgroundColor="{Binding Color, Converter={StaticResource HexToColorConverter}}"
                HorizontalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="16" Opacity="0.5" />
                </Border.Shadow>
                <Label
                    Text="{Binding Label}"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center"
                    VerticalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    MaxLines="3"
                    Padding="14,0" />
            </Border>

            <!-- Label field -->
            <VerticalStackLayout Spacing="8">
                <Label Text="LABEL" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#222222" Padding="16,12">
                    <Entry Text="{Binding Label}"
                           Placeholder="e.g. Chill Playlist"
                           PlaceholderColor="#555"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           ReturnType="Next" />
                </Border>
            </VerticalStackLayout>

            <!-- URI field -->
            <VerticalStackLayout Spacing="8">
                <Label Text="URL / URI" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#222222" Padding="16,12">
                    <Entry Text="{Binding Uri}"
                           Placeholder="e.g. spotify:track:4uLU6hMCjMI75M1A2tKUQC"
                           PlaceholderColor="#555"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           Keyboard="Url"
                           ReturnType="Done" />
                </Border>
                <Label Text="Supports any URI: spotify:, https://, youtube://, google.navigation:q=Address, etc."
                       FontSize="12" TextColor="#666" />
            </VerticalStackLayout>

            <!-- Color picker -->
            <VerticalStackLayout Spacing="12">
                <Label Text="COLOR" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />
                <CollectionView ItemsSource="{Binding PresetColors}"
                                SelectionMode="None"
                                HeightRequest="60">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="{x:Type x:String}">
                            <Border WidthRequest="48" HeightRequest="48"
                                    StrokeShape="Ellipse"
                                    StrokeThickness="3"
                                    Stroke="Transparent"
                                    BackgroundColor="{Binding ., Converter={StaticResource HexToColorConverter}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectColorCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Sound picker (Pro feature) -->
            <VerticalStackLayout Spacing="8">
                <Label Text="SOUND" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" CharacterSpacing="0.5" />
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="#222222" Padding="14,10">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="{Binding SoundName}"
                               TextColor="#CCCCCC"
                               VerticalTextAlignment="Center"
                               FontSize="15" />
                        <Button Grid.Column="1"
                                Text="Choose"
                                Command="{Binding PickSoundCommand}"
                                BackgroundColor="#333" TextColor="White"
                                FontSize="13" Padding="12,6"
                                CornerRadius="8" HeightRequest="36" />
                        <Button Grid.Column="2"
                                Text="✕"
                                IsVisible="{Binding HasSound}"
                                Command="{Binding RemoveSoundCommand}"
                                BackgroundColor="Transparent" TextColor="#888"
                                FontSize="16" Padding="8,0"
                                CornerRadius="8" HeightRequest="36" />
                    </Grid>
                </Border>
                <Label Text="🔒 Pro — custom sounds require EasyButtons Pro"
                       FontSize="12" TextColor="#555" />
            </VerticalStackLayout>

            <!-- Delete button (edit mode only) -->
            <Button
                IsVisible="{Binding IsEdit}"
                Text="Delete Button"
                BackgroundColor="Transparent"
                BorderColor="#E53935"
                BorderWidth="1"
                TextColor="#E53935"
                CornerRadius="12"
                Command="{Binding DeleteCommand}"
                Margin="0,16,0,0" />

            <!-- Pin to home screen (edit mode + device supports it) -->
            <Button
                IsVisible="{Binding CanPin}"
                Text="📌 Pin to Home Screen"
                BackgroundColor="Transparent"
                BorderColor="#555"
                BorderWidth="1"
                TextColor="#AAA"
                CornerRadius="12"
                Command="{Binding PinShortcutCommand}"
                Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
