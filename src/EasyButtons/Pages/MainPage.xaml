<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EasyButtons.Pages.MainPage"
    x:Name="ThisPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:EasyButtons.ViewModels"
    xmlns:m="clr-namespace:EasyButtons.Models"
    xmlns:helpers="clr-namespace:EasyButtons.Helpers"
    x:DataType="vm:MainViewModel"
    Title="EasyButtons"
    BackgroundColor="#111111">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Export Backup"
                     Command="{Binding ExportBackupCommand}"
                     Order="Secondary" />
        <ToolbarItem Text="Import Backup"
                     Command="{Binding ImportBackupCommand}"
                     Order="Secondary" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBg">#111111</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Empty state -->
        <VerticalStackLayout
            Grid.Row="0"
            IsVisible="{Binding IsEmpty}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="16"
            Padding="40">
            <Label Text="🔴" FontSize="64" HorizontalTextAlignment="Center" />
            <Label Text="No buttons yet"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Tap + to add your first easy button."
                   FontSize="14" TextColor="#888"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Button grid -->
        <ScrollView Grid.Row="0" IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}">
            <CollectionView
                ItemsSource="{Binding Buttons}"
                SelectionMode="None"
                Margin="16,16,16,80">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:EasyButton">
                        <!-- Big round Easy Button -->
                        <Grid Padding="6">
                            <Grid.Behaviors>
                                <helpers:ButtonGestureBehavior
                                    TapCommand="{Binding Source={x:Reference ThisPage}, Path=BindingContext.LaunchCommand}"
                                    TapCommandParameter="{Binding .}"
                                    LongPressCommand="{Binding Source={x:Reference ThisPage}, Path=BindingContext.EditCommand}"
                                    LongPressCommandParameter="{Binding .}" />
                            </Grid.Behaviors>

                            <!-- Ground shadow — elliptical, offset down, simulates surface -->
                            <BoxView
                                CornerRadius="72"
                                HeightRequest="144"
                                WidthRequest="148"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Margin="0,18,0,0"
                                Color="#000000"
                                Opacity="0.55" />

                            <!-- Metallic rim — dark radial gradient ring around dome -->
                            <Border
                                HeightRequest="152"
                                WidthRequest="152"
                                StrokeShape="Ellipse"
                                StrokeThickness="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Margin="0,4,0,0">
                                <Border.Background>
                                    <RadialGradientBrush Center="0.38,0.32" Radius="0.75">
                                        <GradientStop Color="#484848" Offset="0" />
                                        <GradientStop Color="#282828" Offset="0.5" />
                                        <GradientStop Color="#181818" Offset="1" />
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Button dome — colored, slightly above rim center -->
                            <Border
                                HeightRequest="138"
                                WidthRequest="138"
                                StrokeShape="Ellipse"
                                StrokeThickness="0"
                                BackgroundColor="{Binding Color, Converter={StaticResource HexToColorConverter}}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Margin="0,0,0,6">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.4" />
                                </Border.Shadow>
                                <Grid>
                                    <!-- Label — pushed below the glare area -->
                                    <Label
                                        Text="{Binding Label}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center"
                                        LineBreakMode="WordWrap"
                                        MaxLines="3"
                                        Padding="12,32,12,4" />
                                    <!-- Wide gloss sweep — upper dome -->
                                    <Border
                                        WidthRequest="94"
                                        HeightRequest="48"
                                        StrokeShape="Ellipse"
                                        StrokeThickness="0"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Start"
                                        Margin="0,12,0,0"
                                        InputTransparent="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#66FFFFFF" Offset="0" />
                                                <GradientStop Color="#22FFFFFF" Offset="0.55" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- Sharp specular point — top-left -->
                                    <Border
                                        WidthRequest="42"
                                        HeightRequest="20"
                                        StrokeShape="Ellipse"
                                        StrokeThickness="0"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start"
                                        Margin="24,12,0,0"
                                        InputTransparent="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#CCFFFFFF" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- FAB — overlays content in Row 0 -->
        <Button
            Grid.Row="0"
            Text="+"
            FontSize="32"
            FontAttributes="Bold"
            BackgroundColor="#E53935"
            TextColor="White"
            CornerRadius="36"
            HeightRequest="72"
            WidthRequest="72"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,24,24"
            Command="{Binding AddCommand}">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.5" />
            </Button.Shadow>
        </Button>

        <!-- Pro upsell hint — shown when free limit reached -->
        <Border
            Grid.Row="0"
            IsVisible="{Binding IsAtFreeLimit}"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,16,100"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="0"
            Padding="10,6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#CC000000" Offset="0" />
                    <GradientStop Color="#CC1a1a1a" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Label Text="🔒 4-button limit · Tap + for Pro"
                   TextColor="#CCCCCC" FontSize="12" />
        </Border>

        <!-- Debug bar: banner + Pro toggle (compile-time zero footprint in Release) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
            <Label x:Name="DebugBanner"
                   IsVisible="False" Text="DEBUG BUILD"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   BackgroundColor="#E65C00" TextColor="White"
                   FontSize="11" FontAttributes="Bold" Padding="0,5" />
            <Button x:Name="DebugProButton"
                    Grid.Column="1"
                    IsVisible="False"
                    Text="Pro: OFF"
                    FontSize="11" FontAttributes="Bold"
                    BackgroundColor="#333" TextColor="#FFD700"
                    Padding="12,5" HeightRequest="32"
                    CornerRadius="0" />
        </Grid>
    </Grid>
</ContentPage>
