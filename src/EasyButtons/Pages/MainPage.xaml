<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EasyButtons.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:EasyButtons.ViewModels"
    xmlns:m="clr-namespace:EasyButtons.Models"
    x:DataType="vm:MainViewModel"
    Title="EasyButtons"
    BackgroundColor="#111111">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBg">#111111</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Empty state -->
        <VerticalStackLayout
            Grid.Row="0"
            IsVisible="{Binding IsEmpty}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="16"
            Padding="40">
            <Label Text="🔴" FontSize="64" HorizontalTextAlignment="Center" />
            <Label Text="No buttons yet"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
            <Label Text="Tap + to add your first easy button."
                   FontSize="14" TextColor="#888"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Button grid -->
        <ScrollView Grid.Row="0" IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}">
            <CollectionView
                ItemsSource="{Binding Buttons}"
                SelectionMode="None"
                Margin="16,16,16,80">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:EasyButton">
                        <!-- Big round Easy Button -->
                        <Grid Padding="4">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.LaunchCommand}"
                                    CommandParameter="{Binding .}" />
                                <TapGestureRecognizer
                                    NumberOfTapsRequired="2"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <!-- Shadow/base layer -->
                            <BoxView
                                CornerRadius="80"
                                HeightRequest="140"
                                WidthRequest="140"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Margin="0,6,0,0"
                                Color="#000000"
                                Opacity="0.4" />

                            <!-- Button dome -->
                            <Border
                                HeightRequest="140"
                                WidthRequest="140"
                                StrokeShape="Ellipse"
                                StrokeThickness="0"
                                BackgroundColor="{Binding Color}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.5" />
                                </Border.Shadow>
                                <Label
                                    Text="{Binding Label}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    MaxLines="3"
                                    Padding="14,0" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- FAB — overlays content in Row 0 -->
        <Button
            Grid.Row="0"
            Text="+"
            FontSize="32"
            FontAttributes="Bold"
            BackgroundColor="#E53935"
            TextColor="White"
            CornerRadius="36"
            HeightRequest="72"
            WidthRequest="72"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="0,0,24,24"
            Command="{Binding AddCommand}">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.5" />
            </Button.Shadow>
        </Button>

        <!-- Debug banner -->
        <Label x:Name="DebugBanner" Grid.Row="1"
               IsVisible="False" Text="DEBUG BUILD"
               HorizontalTextAlignment="Center"
               BackgroundColor="#E65C00" TextColor="White"
               FontSize="11" FontAttributes="Bold" Padding="0,5" />
    </Grid>
</ContentPage>
