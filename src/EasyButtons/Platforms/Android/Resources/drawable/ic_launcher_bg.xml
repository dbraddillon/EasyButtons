<?xml version="1.0" encoding="utf-8"?>
<!--
    Easy Button adaptive icon background.
    Dark base with a red dome and a subtle highlight to give a 3D raised look.
    Safe zone: x:18–90, y:18–90 of a 108dp canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark background -->
    <path android:fillColor="#1a1a1a" android:pathData="M0,0h108v108H0z"/>

    <!-- Outer metallic ring/base (dark grey) -->
    <path android:fillColor="#3a3a3a"
          android:pathData="M54,18 a36,36 0 1,1 0,72 a36,36 0 1,1 0,-72z"/>

    <!-- Inner red dome -->
    <path android:fillColor="#E53935"
          android:pathData="M54,22 a32,32 0 1,1 0,64 a32,32 0 1,1 0,-64z"/>

    <!-- Highlight spot — top-left, gives dome/3D effect -->
    <path android:fillColor="#66FFFFFF"
          android:pathData="M42,30 a12,8 0 1,1 0,0.01z"/>

</vector>
