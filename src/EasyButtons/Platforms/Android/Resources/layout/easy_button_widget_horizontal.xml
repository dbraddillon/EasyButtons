<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="4dp"
    android:background="#00000000">

    <ImageView
        android:id="@+id/widget_btn_0"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:contentDescription="Button 1" />

    <ImageView
        android:id="@+id/widget_btn_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:contentDescription="Button 2" />

    <ImageView
        android:id="@+id/widget_btn_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:contentDescription="Button 3" />

    <ImageView
        android:id="@+id/widget_btn_3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:contentDescription="Button 4" />

</LinearLayout>
